{
    "name": "app-module165-monorepo",
    "version": "0.0.0",
    "private": true,
    "packageManager": "npm@11.11.1",
    "workspaces": [
        "apps/frontend",
        "apps/backend"
    ],
    "scripts": {
        "start": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
        "start:frontend": "npm run start --workspace=apps/frontend",
        "start:backend": "npm run dev --workspace=apps/backend",
        "build": "npm run build:frontend && npm run build:backend",
        "build:frontend": "npm run build --workspace=apps/frontend",
        "build:backend": "npm run build --workspace=apps/backend",
        "test": "npm run test --workspace=apps/frontend",
        "format": "prettier --write \"**/*.{ts,html,scss}\" --ignore-path .prettierignore"
    },
    "devDependencies": {
        "prettier": "^3.8.1"
    },
    "dependencies": {
        "concurrently": "^9.2.1"
    }
}
